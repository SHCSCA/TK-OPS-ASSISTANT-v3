{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TK-OPS",
  "version": "0.4.2",
  "identifier": "com.tkops.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run prepare:media-tools && npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$DESKTOP/**",
          "$DOCUMENT/**",
          "$DOWNLOAD/**",
          "$PICTURE/**",
          "$VIDEO/**"
        ]
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "TK-OPS",
        "width": 1440,
        "height": 960,
        "resizable": true,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/bin/ffprobe/windows-x64/ffprobe.exe"
    ],
    "icon": [
      "../../../tkops.ico"
    ]
  }
}
