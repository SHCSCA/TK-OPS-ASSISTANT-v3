{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TK-OPS",
  "version": "0.3.1",
  "identifier": "com.tkops.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix apps/desktop run dev",
    "beforeBuildCommand": "",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TK-OPS",
        "width": 1440,
        "height": 960,
        "resizable": true,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../../../tkops.ico"
    ]
  }
}
